# tokenmoth-api configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tokenmoth
BIND_ADDR=0.0.0.0:8080
RUST_LOG=tokenmoth_api=info,tower_http=info

# Optional: self-seed a user + key on startup (docker-compose uses this).
TOKENMOTH_BOOTSTRAP_KEY=tm_user_123
TOKENMOTH_BOOTSTRAP_EMAIL=me@tokenmoth.local
# Admin token gating /v1/keys (key management). Unset = key mgmt disabled.
TOKENMOTH_ADMIN_TOKEN=tm_admin_dev
# Per-key rate limit (requests/min) for /v1/telemetry.
TOKENMOTH_RATE_PER_MIN=120
