# tokenmoth-api configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tokenmoth
BIND_ADDR=0.0.0.0:8080
RUST_LOG=tokenmoth_api=info,tower_http=info

# Optional: self-seed a user + key on startup (docker-compose uses this).
TOKENMOTH_BOOTSTRAP_KEY=tm_user_123
TOKENMOTH_BOOTSTRAP_EMAIL=me@tokenmoth.local
# Admin token gating /v1/keys (key management). Unset = key mgmt disabled.
TOKENMOTH_ADMIN_TOKEN=tm_admin_dev
# Per-key rate limit (requests/min) for /v1/telemetry.
TOKENMOTH_RATE_PER_MIN=120

# ---- Billing (#33/#34) -----------------------------------------------------
# All optional. With STRIPE_SECRET_KEY unset, /v1/plan reports billing disabled,
# checkout returns 501, and every user stays on the free tier. Set these (and
# edit the TIERS table in src/main.rs) to enable paid plans.
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...            # for POST /v1/billing/webhook
# STRIPE_PRICE_PRO=price_...                 # Stripe price id for the Pro tier
# STRIPE_PRICE_MAX=price_...                 # Stripe price id for the Max tier
# APP_BASE_URL=https://app.tokenmoth.com     # checkout success/cancel redirects
